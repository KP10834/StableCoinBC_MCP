# ----------------------------------------
# Kafka (kafka-mcp)
# ----------------------------------------
# 브로커 주소 (여러 개면 콤마로 구분: host1:9092,host2:9092)
KAFKA_BROKERS=

# ----------------------------------------
# Redis (redis-mcp)
# ----------------------------------------
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
# 데이터베이스 번호 (기본값 0)
REDIS_DB=0
# 키 검색 시 prefix 필터 (선택)
REDIS_KEY_PREFIX=

# ----------------------------------------
# Elasticsearch / ELK (elk-mcp)
# ----------------------------------------
ES_URL=
# API Key 인증 (권장)
ES_API_KEY=
# 또는 Basic Auth
ES_USER=
ES_PASSWORD=
# 검색할 인덱스 패턴 (예: logs-*, filebeat-*)
ES_INDEX_PATTERN=logs-*

# ----------------------------------------
# EVM RPC (evm-mcp)
# ----------------------------------------
# 연결할 체인의 RPC URL (Infura, Alchemy, 자체 노드 등)
EVM_RPC_URL=
# RPC 요청 타임아웃 ms (기본값 10000)
RPC_TIMEOUT_MS=10000

# ----------------------------------------
# GitHub (cross-impact-mcp, workflow-mcp)
# ----------------------------------------
# GitHub Personal Access Token (repo 읽기/쓰기 권한)
GITHUB_TOKEN=
# GitHub API URL (기본값: https://api.github.com)
GITHUB_API_URL=https://api.github.com
# 분석 대상 레포 목록 (JSON 배열, cross-impact-mcp용)
# 예: [{"name":"StableCoinBC_Adapter","owner":"KP10834"},{"name":"StableCoinBC_API","owner":"KP10834"}]
REPOS=

# ----------------------------------------
# SQLite (sqlite-mcp)
# ----------------------------------------
# DB 이름과 파일 경로 매핑 (JSON 객체)
# 예: {"main":"/path/to/main.db","logs":"/path/to/logs.db"}
SQLITE_DATABASES=

# ----------------------------------------
# GitHub Wiki (github-wiki-mcp)
# ----------------------------------------
# GITHUB_TOKEN 재사용. 별도 변수:
# Wiki 대상 레포 (JSON map). key=단축명, value=owner/repo
# 예: {"adapter":"StableCoinTF/StableCoinBC_Adapter","docs":"StableCoinTF/StableCoinBC_Adapter_Docs"}
WIKI_REPOS=
# clone 캐시 디렉터리 (기본: ~/.cache/github-wiki-mcp)
WIKI_CACHE_DIR=
# 같은 레포 재pull 최소 간격 (초, 기본: 300)
WIKI_PULL_TTL_SEC=300

# ----------------------------------------
# Grafana (grafana-mcp)
# ----------------------------------------
# Grafana 베이스 URL (필수)
GRAFANA_URL=
# Service Account Token (권장, Grafana 9.1+) — glsa_ 로 시작
GRAFANA_SA_TOKEN=
# 레거시 API Key (SA Token 없을 때 fallback)
GRAFANA_API_KEY=
# 데이터소스 UID (grafana_datasources 도구로 확인 후 입력)
GRAFANA_PROM_DATASOURCE_UID=
GRAFANA_LOKI_DATASOURCE_UID=

# ----------------------------------------
# Kibana (kibana-mcp)
# ----------------------------------------
# Kibana 베이스 URL (필수)
KIBANA_URL=
# API Key (권장) — Stack Management → API keys 에서 발급된 encoded 값
KIBANA_API_KEY=
# 또는 세션 쿠키 (SSO 환경 fallback). 형식: "sid=...; ..."
KIBANA_COOKIE=

# ----------------------------------------
# Slack (slack-mcp)
# ----------------------------------------
# Bot Token (xoxb-) — postMessage / history / replies 용
# Slack App 만들고 채널에 초대 + 다음 scopes 부여:
#   chat:write, channels:history, groups:history, channels:read, groups:read
SLACK_BOT_TOKEN=
# User Token (xoxp-) — search.messages 용 (선택)
# scopes: search:read
SLACK_USER_TOKEN=
# 기본 발송 채널 (선택, channel 파라미터 생략 시 사용)
SLACK_DEFAULT_CHANNEL=

# ----------------------------------------
# QA / 로컬 실행 (qa-mcp)
# ----------------------------------------
# 프로젝트 루트 디렉토리 절대 경로
PROJECT_DIR=
# 테스트 데이터 디렉토리 (선택)
DATA_DIR=
