# ----------------------------------------
# Kafka (kafka-mcp)
# ----------------------------------------
# 브로커 주소 (여러 개면 콤마로 구분: host1:9092,host2:9092)
KAFKA_BROKERS=

# ----------------------------------------
# Redis (redis-mcp)
# ----------------------------------------
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
# 데이터베이스 번호 (기본값 0)
REDIS_DB=0
# 키 검색 시 prefix 필터 (선택)
REDIS_KEY_PREFIX=

# ----------------------------------------
# Elasticsearch / ELK (elk-mcp)
# ----------------------------------------
ES_URL=
# API Key 인증 (권장)
ES_API_KEY=
# 또는 Basic Auth
ES_USER=
ES_PASSWORD=
# 검색할 인덱스 패턴 (예: logs-*, filebeat-*)
ES_INDEX_PATTERN=logs-*

# ----------------------------------------
# EVM RPC (evm-mcp)
# ----------------------------------------
# 연결할 체인의 RPC URL (Infura, Alchemy, 자체 노드 등)
EVM_RPC_URL=
# RPC 요청 타임아웃 ms (기본값 10000)
RPC_TIMEOUT_MS=10000

# ----------------------------------------
# GitHub (cross-impact-mcp, workflow-mcp)
# ----------------------------------------
# GitHub Personal Access Token (repo 읽기/쓰기 권한)
GITHUB_TOKEN=
# GitHub API URL (기본값: https://api.github.com)
GITHUB_API_URL=https://api.github.com
# 분석 대상 레포 목록 (JSON 배열, cross-impact-mcp용)
# 예: [{"name":"StableCoinBC_Adapter","owner":"KP10834"},{"name":"StableCoinBC_API","owner":"KP10834"}]
REPOS=

# ----------------------------------------
# SQLite (sqlite-mcp)
# ----------------------------------------
# DB 이름과 파일 경로 매핑 (JSON 객체)
# 예: {"main":"/path/to/main.db","logs":"/path/to/logs.db"}
SQLITE_DATABASES=

# ----------------------------------------
# QA / 로컬 실행 (qa-mcp)
# ----------------------------------------
# 프로젝트 루트 디렉토리 절대 경로
PROJECT_DIR=
# 테스트 데이터 디렉토리 (선택)
DATA_DIR=
