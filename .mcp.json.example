{
  "mcpServers": {
    "kafka-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/kafka-mcp/index.js"],
      "env": {
        "KAFKA_BROKERS": "localhost:9092"
      }
    },
    "redis-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/redis-mcp/index.js"],
      "env": {
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "REDIS_KEY_PREFIX": "bc-adapter:"
      }
    },
    "sqlite-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/sqlite-mcp/index.js"],
      "env": {
        "DATA_DIR": "./data"
      }
    },
    "evm-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/evm-mcp/index.js"],
      "env": {
        "EVM_RPC_URL": "http://localhost:8545",
        "RPC_TIMEOUT_MS": "10000"
      }
    },
    "pm2-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/pm2-mcp/index.js"]
    },
    "error-log-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/error-log-mcp/index.js"]
    }
  }
}
