{
  "mcpServers": {
    "kafka-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/kafka-mcp/index.js"],
      "env": {
        "KAFKA_BROKERS": "localhost:9092"
      }
    },
    "redis-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/redis-mcp/index.js"],
      "env": {
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "REDIS_KEY_PREFIX": "bc-adapter:"
      }
    },
    "sqlite-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/sqlite-mcp/index.js"],
      "env": {
        "DATA_DIR": "./data"
      }
    },
    "evm-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/evm-mcp/index.js"],
      "env": {
        "EVM_RPC_URL": "http://localhost:8545",
        "RPC_TIMEOUT_MS": "10000"
      }
    },
"elk-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/elk-mcp/index.js"],
      "env": {
        "ES_URL": "http://localhost:9200",
        "ES_API_KEY": "<your-es-api-key>",
        "ES_INDEX_PATTERN": "logs-*"
      }
    },
    "workflow-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/workflow-mcp/index.js"]
    },
    "release-note-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/release-note-mcp/index.js"]
    },
    "qa-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/qa-mcp/index.js"]
    },
    "cross-impact-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/@stablecointf/mcp-servers/packages/cross-impact-mcp/index.js"],
      "env": {
        "GITHUB_TOKEN": "<your-github-token>",
        "GITHUB_API_URL": "https://api.github.com",
        "BASE_BRANCH": "main",
        "REPOS": "{\"adapter\":\"StableCoinTF/StableCoinBC_Adapter\",\"backend\":{\"repo\":\"StableCoinTF/StableCoinBE_Wallet\",\"base\":\"wallet_master\"},\"listener\":\"StableCoinTF/StableCoinBC_Adapter_Listener\",\"docs\":\"StableCoinTF/StableCoinBC_Adapter_Docs\"}"
      }
    }
  }
}
